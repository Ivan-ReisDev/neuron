# ============================================================================
# .env.docker.example — Template para o stack Docker do Neuron API (VPS)
#
# Uso:
#   cp .env.docker.example .env.docker
#   # editar valores marcados com "MUDAR"
#   docker compose --env-file .env.docker up -d
# ============================================================================

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000

# ----------------------------------------------------------------------------
# Banco (Neon Postgres — externo, gerenciado fora da VPS)
# ----------------------------------------------------------------------------
DB_HOST=                              # MUDAR: host do Neon (ex: ep-xxx.neon.tech)
DB_PORT=5432
DB_USERNAME=                          # MUDAR
DB_PASSWORD=                          # MUDAR
DB_NAME=                              # MUDAR
DB_SSL=true

# ----------------------------------------------------------------------------
# AI Provider
# ----------------------------------------------------------------------------
AI_PROVIDER_NAME=groq
GEMINI_API_KEY=                       # MUDAR
GROQ_API_KEY=                         # MUDAR

# ----------------------------------------------------------------------------
# Auth
# ----------------------------------------------------------------------------
JWT_SECRET=                           # MUDAR (string aleatória forte)
JWT_EXPIRATION=86400

# ----------------------------------------------------------------------------
# Storage (Cloudflare R2 — externo)
# ----------------------------------------------------------------------------
R2_ACCOUNT_ID=                        # MUDAR
R2_ACCESS_KEY_ID=                     # MUDAR
R2_SECRET_ACCESS_KEY=                 # MUDAR
R2_BUCKET_NAME=                       # MUDAR
R2_SIGNED_URL_EXPIRATION=3600

# ----------------------------------------------------------------------------
# E-mail (Resend — preferido) + Gmail SMTP (fallback)
# ----------------------------------------------------------------------------
RESEND_API_KEY=                       # MUDAR
RESEND_FROM=Ivan Reis <contato@ivanreis.com.br>
RESEND_REPLY_TO=contato@ivanreis.com.br

GMAIL_USER=                           # MUDAR (opcional)
GMAIL_APP_PASSWORD=                   # MUDAR (opcional)

# ----------------------------------------------------------------------------
# WhatsApp (Chromium já vem na imagem)
# ----------------------------------------------------------------------------
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# ----------------------------------------------------------------------------
# Outros
# ----------------------------------------------------------------------------
PIX_KEY=                              # MUDAR (opcional)
TURNSTILE_SECRET_KEY=                 # MUDAR (Cloudflare Turnstile)

# ----------------------------------------------------------------------------
# Imagem Docker
# Em DEV LOCAL: deixe vazio/comentado -> docker compose builda local
# Em PRODUÇÃO (VPS): aponta pra imagem publicada via GitHub Actions no ghcr.io
# ----------------------------------------------------------------------------
# API_IMAGE=ghcr.io/ivan-reisdev/neuron-api:latest
